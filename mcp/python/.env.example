# ============================================================================
# AI Reminder System - Environment Configuration
# ============================================================================

# Your User ID (unique identifier)
USER_ID=your_user_id_here

# ============================================================================
# TWILIO WHATSAPP (Option 1 - Recommended for individuals)
# ============================================================================

# Get these from https://www.twilio.com/console
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token_here

# Get these from WhatsApp Sandbox setup
# TWILIO_WHATSAPP_FROM should be: whatsapp:+1234567890 (Twilio sandbox number)
# WHATSAPP_TO_NUMBER should be: whatsapp:+your_phone_number
TWILIO_WHATSAPP_FROM=whatsapp:+1234567890
WHATSAPP_TO_NUMBER=whatsapp:+1234567890

# ============================================================================
# WHATSAPP BUSINESS API (Option 2 - Enterprise)
# ============================================================================

# Get these from Meta/Facebook Developers
# Only needed if using WhatsApp Business API
WHATSAPP_BUSINESS_PHONE_ID=your_phone_id
WHATSAPP_BUSINESS_ACCOUNT_ID=your_account_id
WHATSAPP_BUSINESS_ACCESS_TOKEN=your_access_token
WHATSAPP_RECIPIENT_PHONE=+1234567890

# ============================================================================
# TELEGRAM (if using Telegram notifications)
# ============================================================================

TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_telegram_chat_id

# ============================================================================
# EMAIL (if using email notifications)
# ============================================================================

EMAIL_FROM=your_email@gmail.com
EMAIL_PASSWORD=your_app_password
EMAIL_TO=recipient@example.com
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587

# ============================================================================
# API KEYS & TOKENS
# ============================================================================

# Your API keys for various services
API_KEY=your_api_key_here
API_SECRET=your_api_secret_here

# ============================================================================
# DATABASE & STORAGE
# ============================================================================

DATABASE_URL=your_database_url
REDIS_URL=your_redis_url

# ============================================================================
# LOGGING & DEBUG
# ============================================================================

# Set to "true" for verbose logging
DEBUG=false
LOG_LEVEL=INFO

# ============================================================================
# NOTES:
# ============================================================================
# 1. Never commit this file to git
# 2. Use different values for development/production
# 3. Rotate secrets periodically
# 4. Keep sensitive values secure (don't share)
# 5. For development: use Twilio sandbox
# 6. For production: use WhatsApp Business API
