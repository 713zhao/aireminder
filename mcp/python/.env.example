# Firebase Configuration
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_PRIVATE_KEY=-----BEGIN PRIVATE KEY-----\nMIIEvQI...\n-----END PRIVATE KEY-----\n
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-abc@your-project.iam.gserviceaccount.com

# User Context (can be overridden per request)
USER_ID=user@example.com

# Optional: Debug mode
DEBUG=false

# ============================================================================
# NOTIFICATION SCHEDULER CONFIGURATION
# ============================================================================

# Morning Summary Notification
# Time to send daily summary of today's reminders (24-hour format)
MORNING_SUMMARY_HOUR=7
MORNING_SUMMARY_MINUTE=0

# Pre-Event Reminder
# Send reminder N minutes before event starts
PRE_EVENT_REMINDER_MINUTES=15

# How often to check for upcoming reminders (seconds)
NOTIFICATION_CHECK_INTERVAL_SECONDS=60

# ============================================================================
# EMAIL CONFIGURATION
# ============================================================================

# Enable/disable Email notifications
ENABLE_EMAIL=false

# SMTP Server configuration
# For Gmail: smtp.gmail.com
# For Outlook: smtp-mail.outlook.com
# For Yahoo: smtp.mail.yahoo.com
SMTP_SERVER=smtp.gmail.com

# SMTP Port (usually 587 for TLS, 465 for SSL)
SMTP_PORT=587

# Sender email address (should match Gmail/email provider)
# Example: your-email@gmail.com
SENDER_EMAIL=your-email@gmail.com

# Sender email password or App Password
# For Gmail: Use App Password (https://myaccount.google.com/apppasswords)
# For security: Use environment variable instead of storing here
SENDER_PASSWORD=your-app-password

# ============================================================================
# TELEGRAM CONFIGURATION
# ============================================================================

# Enable/disable Telegram notifications
ENABLE_TELEGRAM=true

# Get from BotFather on Telegram: https://t.me/botfather
# Commands:
#   /newbot -> answer questions -> receive TOKEN
TELEGRAM_BOT_TOKEN=YOUR_TELEGRAM_BOT_TOKEN

# Your Telegram Chat ID
# Get it from: https://t.me/userinfobot
# Or send /start to @userinfobot and it will tell you your chat ID
TELEGRAM_CHAT_ID=YOUR_TELEGRAM_CHAT_ID

# ============================================================================
# WHATSAPP CONFIGURATION
# ============================================================================

# Enable/disable WhatsApp notifications
ENABLE_WHATSAPP=true

# WhatsApp method: "twilio" or "business"
# - twilio: Easier setup, uses Twilio sandbox or production number
# - business: Uses WhatsApp Business API (more advanced)
WHATSAPP_METHOD=twilio

# --- TWILIO CONFIGURATION (if using WHATSAPP_METHOD=twilio) ---

# Twilio Credentials
# Get from: https://www.twilio.com/console
TWILIO_ACCOUNT_SID=YOUR_TWILIO_ACCOUNT_SID
TWILIO_AUTH_TOKEN=YOUR_TWILIO_AUTH_TOKEN

# Twilio WhatsApp Sender
# Sandbox: whatsapp:+14155238886
# Production: whatsapp:+YOUR_TWILIO_NUMBER
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# Your WhatsApp recipient phone number (with country code)
# Example: +1234567890
WHATSAPP_RECIPIENT_PHONE=+YOUR_PHONE_NUMBER

# --- WHATSAPP BUSINESS API CONFIGURATION (if using WHATSAPP_METHOD=business) ---

# WhatsApp Business API endpoint
WHATSAPP_BUSINESS_API_URL=https://graph.instagram.com/v18.0

# Your WhatsApp Business Phone ID
WHATSAPP_BUSINESS_PHONE_ID=YOUR_PHONE_ID

# WhatsApp Business API Access Token
WHATSAPP_BUSINESS_ACCESS_TOKEN=YOUR_ACCESS_TOKEN

# Recipient phone number (with country code, no + or -)
# Example: 1234567890
WHATSAPP_RECIPIENT_PHONE=YOUR_PHONE_NUMBER
